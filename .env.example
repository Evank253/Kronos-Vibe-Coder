### Copy this file to `.env` and fill values for local development

# ── GitHub OAuth ────────────────────────────────────────────────────────────
# Create an OAuth App in GitHub Settings → Developer settings → OAuth Apps
GITHUB_OAUTH_CLIENT_ID=your_client_id_here
GITHUB_OAUTH_CLIENT_SECRET=your_client_secret_here

# Optional: personal token fallback (not required if using OAuth flow)
# GITHUB_TOKEN=ghp_...

# ── Session ──────────────────────────────────────────────────────────────────
# Set to a long random string in production (e.g. python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=change-me-to-a-random-secret

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO
# Set to 1 when running behind HTTPS to add 'secure' flag to session cookies
HTTPS_ONLY=0

# ── Redis (optional) ─────────────────────────────────────────────────────────
# Uncomment to use Redis for persistent sessions
# REDIS_URL=redis://localhost:6379/0

# ── AI / LLM provider ────────────────────────────────────────────────────────
# Used by the chatbot for fix suggestions (/suggest-fixes endpoint).
# Leave blank to get rule-based summaries only (no LLM calls).
#
# OpenAI:
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_API_KEY=sk-...
#   AI_MODEL=gpt-4o-mini
#
# Azure OpenAI:
#   AI_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   AI_API_KEY=<azure-key>
#   AI_MODEL=gpt-4o
#
# Ollama (local):
#   AI_BASE_URL=http://localhost:11434/v1
#   AI_API_KEY=ollama
#   AI_MODEL=llama3
#
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ── Sentry (optional) ────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Integration tests ────────────────────────────────────────────────────────
# Set to 1 to run integration tests (requires GitHub credentials)
# RUN_INTEGRATION=0


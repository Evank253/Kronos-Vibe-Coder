# Vault-first setup (recommended)
# 1) Set VAULT_MASTER_KEY to a long random value.
# 2) Use: python -m backend.cli.vault_cli store <KEY> --value <VALUE>
# 3) App reads from encrypted .secrets.vault first, then falls back to .env.
VAULT_MASTER_KEY=
VAULT_FILE=.secrets.vault

### Backward-compatible `.env` fallback (used when VAULT_MASTER_KEY is unset)
# GitHub OAuth app credentials (create an OAuth App in GitHub settings)
GITHUB_OAUTH_CLIENT_ID=your_client_id_here
GITHUB_OAUTH_CLIENT_SECRET=your_client_secret_here

# Optional AI provider secret (can be stored in vault instead)
AI_API_KEY=your_ai_api_key_here

# Optional: personal token fallback (not required if using OAuth flow)
# GITHUB_TOKEN=ghp_...

# Session secret for signing cookies (set to a long random string in production)
SESSION_SECRET=change-me-to-a-random-secret

# Server port
PORT=8080

# Optional Redis URL for session storage
REDIS_URL=redis://localhost:6379/0

# Set to 1 to run integration tests (requires GitHub credentials)
# RUN_INTEGRATION=0
